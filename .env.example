# ─── Database Connections (Supabase) ──────────────────────────────────────────
SUPABASE_PG_URL=postgresql://postgres:your-password@db.wvdqkbwwmvnzpeslehko.supabase.co:5432/postgres

# ─── Neo4j Connections ────────────────────────────────────────────────────────
# Local Docker Secrets (Used by pathfinder.py locally)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your-local-password"

# Remote AuraDB Credentials (Used in render.yaml)
AURA_NEO4J_USER="your-aura-username"
AURA_NEO4J_PASSWORD="your-aura-password"
AURA_NEO4J_URI="neo4j+s://your-instance.databases.neo4j.io"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secure-random-secret

# ─── Internal Service URLs (Handled by render.yaml but good to have) ─────────
# NLP_SERVICE_URL=http://fyp-nlp:8000
# GRAPH_SERVICE_URL=http://fyp-graph:8001

# ─── Frontend Config ──────────────────────────────────────────────────────────
# Set this to your frontend URL (e.g. https://fyp-frontend.onrender.com)
ALLOWED_ORIGINS=http://localhost:5173
VITE_GATEWAY_URL=http://localhost:8080

# ─── Resume Feature ───────────────────────────────────────────────────────────
# Max PDF generation calls per minute per user (default: 5)
RESUME_RATE_LIMIT_PER_MIN=5

# ─── JIT Graph Generation ─────────────────────────────────────────────────────
# Hugging Face token for Serverless Inference API.
# Required for Just-In-Time subgraph generation when a target role is not in Neo4j.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: override the default LLM (Mistral-7B-Instruct-v0.2)
# JIT_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
